{
  "name": "ticketplatform-customer-fe",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev --host 0.0.0.0",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:dirty": "git diff --name-only --diff-filter=ACMR | grep -E '\\.(vue|ts|js|css)$' | xargs -r prettier --write",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@pinia/colada": "^1.3.1",
    "@pinia/nuxt": "^0.11.3",
    "@tabler/icons-vue": "^3.44.0",
    "dompurify": "^3.4.11",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.2.1",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.24",
    "vue-sonner": "^2.0.9",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.10.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^26.0.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
